{
  "name": "tailings",
  "version": "0.0.2",
  "description": "Pull a directory's coding-agent session history (Claude Code, Codex, OpenCode, Gemini) into that directory so the next agent is instantly caught up.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WaryaWayne/tailings.git"
  },
  "bugs": {
    "url": "https://github.com/WaryaWayne/tailings/issues"
  },
  "homepage": "https://github.com/WaryaWayne/tailings",
  "bin": {
    "tailings": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "rolldown packages/cli/src/Main.ts --platform node --format esm --file dist/cli.js",
    "cli": "pnpm build && node dist/cli.js",
    "pull": "pnpm build && node dist/cli.js pull",
    "publish:npm": "pnpm build && npm publish --access public --ignore-scripts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm typecheck && vitest run",
    "prepare": "effect-language-service patch"
  },
  "keywords": [
    "tailings",
    "claude-code",
    "codex",
    "opencode",
    "gemini",
    "coding-agents",
    "cli",
    "sessions",
    "memory",
    "local-first",
    "effect",
    "node"
  ],
  "author": "Warya Wayne",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@effect/language-service": "^0.86.1",
    "@effect/vitest": "4.0.0-beta.74",
    "@types/node": "^25.6.2",
    "rolldown": "1.0.2",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.15",
    "@effect/platform-node": "4.0.0-beta.74",
    "@openai/codex-sdk": "^0.135.0",
    "@opencode-ai/sdk": "^1.15.12",
    "effect": "4.0.0-beta.74"
  }
}
